# Copie este arquivo para .env no servidor/PC que executará a automação.
# Não versionar .env real. Senha em repositório é convite formal para o caos.

# URL do CockroachDB Cloud. Exemplo seguro, sem senha real:
COCKROACH_DATABASE_URL="postgresql://rpa_user:yzDI067N1yBTXsRXnYfcOg@bulky-marmot-27729.j77.aws-us-east-1.cockroachlabs.cloud:26257/rpa_ssrs?sslmode=verify-full"

# Database do projeto
COCKROACH_DATABASE_NAME="rpa_ssrs"

# Caminho do certificado CA do CockroachDB, quando usar sslmode=verify-full
# Se omitido, o app tenta usar certs/root.crt
COCKROACH_SSLROOTCERT="certs/root.crt"

# Modo padrão de carga no banco: upsert, incremental, append ou replace
DB_MODE_DEFAULT="upsert"

# Evita carregar o dia ainda aberto na rotina automática
BLOQUEAR_DIA_ATUAL="true"
